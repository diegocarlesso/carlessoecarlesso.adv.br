Options -Indexes
ServerSignature Off

# Bloquear acesso a arquivos sensíveis
<FilesMatch "(\.env|\.git|composer\.json|composer\.lock|package\.json|\.htpasswd|\.DS_Store)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear config fora do public_html (redundância)
<FilesMatch "\.(env|bak|sql|log|sh|py|rb|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Forçar HTTPS
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Roteamento principal
RewriteEngine On
RewriteBase /

# Arquivos e diretórios reais passam direto
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Admin e API têm seus próprios roteamentos
RewriteCond %{REQUEST_URI} !^/admin/
RewriteCond %{REQUEST_URI} !^/api/

# Tudo vai para index.php
RewriteRule ^(.*)$ index.php?slug=$1 [L,QSA]

# Cabeçalhos de segurança
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache estático
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
