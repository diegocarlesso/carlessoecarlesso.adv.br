Options -Indexes
ServerSignature Off

# Bloquear acesso a arquivos sensíveis
<FilesMatch "(\.env|\.git|composer\.json|composer\.lock|package\.json|\.htpasswd|\.DS_Store|phpunit\.xml)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear config fora do public_html (redundância)
<FilesMatch "\.(env|bak|sql|log|sh|py|rb|ini|lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acesso direto a /vendor/ /src/ /bin/ caso sejam dropadas dentro do public_html.
# (No layout padrão essas pastas vivem fora do public_html, mas este redirecionamento
# protege quem por desencargo ou hospedagem com restrições as colocou aqui.)
RedirectMatch 404 /\.git
RedirectMatch 404 /vendor/.*
RedirectMatch 404 /src/.*
RedirectMatch 404 /bin/.*

# Forçar HTTPS
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Roteamento principal
RewriteEngine On
RewriteBase /

# Arquivos e diretórios reais passam direto
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Admin e API têm seus próprios roteamentos
RewriteCond %{REQUEST_URI} !^/admin/
RewriteCond %{REQUEST_URI} !^/api/

# Tudo vai para index.php
RewriteRule ^(.*)$ index.php?slug=$1 [L,QSA]

# Cabeçalhos de segurança
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Content Security Policy — modo Report-Only (Phase 1 rev 1.2).
    # Após uma semana sem violações no log (storage/cache/csp-reports.log),
    # Phase 4 troca para Content-Security-Policy enforced.
    # Note style-src-attr 'unsafe-inline' — necessário pela estratégia de CSS de §3.6
    # (atributos style="..." controlados em blocos predefinidos).
    Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src-attr 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-src 'self' https://www.google.com https://www.openstreetmap.org; object-src 'none'; base-uri 'self'; form-action 'self'; report-uri /api/csp-report.php"
</IfModule>

# Cache estático
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
