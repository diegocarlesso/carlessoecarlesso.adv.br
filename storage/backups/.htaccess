# Defesa em profundidade — o /storage/.htaccess pai já bloqueia tudo,
# mas mantemos esta cópia caso /storage/.htaccess seja removido por engano.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

Options -Indexes
